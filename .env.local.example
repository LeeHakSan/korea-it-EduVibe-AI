# ──────────────────────────────────────────────────────────────
# EduVibe-AI 환경변수 가이드
# 이 파일을 복사해 .env.local 로 저장하고 실제 값을 채우세요.
# .env.local 은 git 에 절대 커밋하지 마세요 (.gitignore 에 포함됨)
# ──────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Supabase 프로젝트의 API URL
# 위치: Supabase 대시보드 → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# 공개 익명 키 (클라이언트 & 서버 양쪽에서 사용, RLS 정책이 적용됨)
# 위치: Supabase 대시보드 → Settings → API → anon public
# ⚠️  NEXT_PUBLIC_ 접두사 = 브라우저에 노출됨. RLS 정책으로 반드시 보호할 것.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxx

# 서비스 롤 키 (RLS 우회, 반드시 서버에서만 사용)
# 위치: Supabase 대시보드 → Settings → API → service_role secret
# ⚠️  절대 NEXT_PUBLIC_ 접두사를 붙이지 말 것. 브라우저에 노출되면 치명적.
# 사용처: lib/supabase-server.ts의 createAdminClient() (관리자 API Route 전용)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxx

# ── AI ────────────────────────────────────────────────────────
# Google Gemini API 키 (AI 튜터 챗봇 & 자료 요약에 사용)
# 위치: https://aistudio.google.com/app/apikey
# ⚠️  현재 NEXT_PUBLIC_ 로 선언되어 브라우저에 노출됨.
#     프로덕션에서는 서버 전용(GEMINI_API_KEY)으로 변경하고
#     app/api/chat/route.ts 에서만 사용하는 것을 권장.
NEXT_PUBLIC_GEMINI_API_KEY=AIzaSy_xxxx
# (권장) 서버 전용으로 이전 시 아래 키 사용:
# GEMINI_API_KEY=AIzaSy_xxxx
